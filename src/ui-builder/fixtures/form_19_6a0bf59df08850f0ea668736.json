                        "value": "Header",
                        "computeType": "function",
                        "fnSource": "      var value = form.data.created_at;\n      var formatted = value;\n\n      try {\n          var date;\n\n          if (value instanceof Date) {\n              date = value;\n          } else if (typeof value === 'string') {\n              // Parse ISO string and handle 'Z' timezone indicator\n              var isoString = value.replace('Z', '+00:00');\n              date = new Date(isoString);\n          }\n\n          if (date && !isNaN(date.getTime())) {\n              // Convert UTC to IST (UTC+5:30)\n              var istOffset = 5.5 * 60 * 60 * 1000; // 5 hours 30 minutes in milliseconds\n              var istDate = new Date(date.getTime() + istOffset);\n\n              var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n                           'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n\n              var month = months[istDate.getUTCMonth()];\n              var day = istDate.getUTCDate();\n              var year = istDate.getUTCFullYear();\n\n              var hours = istDate.getUTCHours();\n              var minutes = istDate.getUTCMinutes();\n              var ampm = hours >= 12 ? 'PM' : 'AM';\n\n              hours = hours % 12;\n              hours = hours ? hours : 12;\n\n              var minutesStr = minutes < 10 ? '0' + minutes : minutes;\n\n              // Format: \"Apr 24, 2025 - 11:32 AM\" (matches backend)\n              formatted = month + ' ' + day + ', ' + year + ' - ' + hours + ':' + minutesStr + ' ' + ampm;\n          }\n      } catch (e) {\n          // Return original value on error\n      }\n      return formatted || \"-\";"
                      },
