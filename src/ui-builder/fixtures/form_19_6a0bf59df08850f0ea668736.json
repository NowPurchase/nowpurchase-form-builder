  "actions": {
    "setShiftByTime": {
      "body": "    function getShift(timeString) {\n    // Extract hours from time string (e.g., '22:00:00' -> 22)\n    const hours = parseInt(timeString.split(':')[0], 10);\n    \n    if (hours >= 6 && hours < 14) {\n        return 'A'; // Shift A: 06:00 - 14:00\n    } else if (hours >= 14 && hours < 22) {\n        return 'B'; // Shift B: 14:00 - 22:00\n    } else {\n        return 'C'; // Shift C: 22:00 - 06:00\n    }\n}\n\n      const targetKey = `${args.field_data_key}`;\n      const time = e.args[0]; // e.g., '22:00:00'\n        const shift = getShift(time);\n        e.data[targetKey] = shift;",
      "params": {
        "field_data_key": "string"
      }
    },
    "setDefaultDateTime": {
      "body": "const now = new Date().toISOString(); e.store.form.data.rsDateTime = now;",
      "params": {}
    },
    "set_upload_url": {
      "body": "    if (e.args[1]?.fileKey && e.args[0]?.file_url) {\n        // Store in global map\n        if (!window.__fileUrlMap) window.__fileUrlMap = {};\n        window.__fileUrlMap[e.args[1].fileKey] = e.args[0].file_url;\n\n        // Sync ALL stored URLs to current attachment array\n        if (e.data.attachment) {\n            e.data.attachment.forEach(item => {\n                if (window.__fileUrlMap[item.fileKey]) {\n                    item.file_url = window.__fileUrlMap[item.fileKey];\n                    item.status = 'finished';\n                }\n            });\n        }\n    }",
      "params": {}
    },
    "on_time_mount": {
      "body": "    if(!e.data?.time){\n        e.data.time = new Date();\n    }\n\n    function getShift(timeString) {\n    // Extract hours from time string (e.g., '22:00:00' -> 22)\n    const hours = parseInt(timeString.split(':')[0], 10);\n    \n    if (hours >= 6 && hours < 14) {\n        return 'A'; // Shift A: 06:00 - 14:00\n    } else if (hours >= 14 && hours < 22) {\n        return 'B'; // Shift B: 14:00 - 22:00\n    } else {\n        return 'C'; // Shift C: 22:00 - 06:00\n    }\n}\n\n    if(!e.data?.shift){\n      const time = e.data.time;\n        const shift = getShift(time);\n        e.data[\"shift\"] = shift;\n    }",
      "params": {}
    },
    "set_date_on_mount": {
      "body": "    if(!e.data?.date){\n        e.data.date = new Date();\n    }",
      "params": {}
    }
  },
  "formValidator": "    const errors = {};\n\n    if (window.__FORM_IS_REJECTING__) {\n          if (!formData.rejection_reason || formData.rejection_reason.toString().trim() === '') {\n            errors['rejection_reason'] = 'Please select a rejection reason';\n        }\n        // if (!formData.remarks || formData.remarks.toString().trim() === '') {\n        //     errors['remarks'] = 'Remarks is required when rejecting';\n        // }\n    }\n\n    return Object.keys(errors).length > 0 ? errors : undefined;\n",
