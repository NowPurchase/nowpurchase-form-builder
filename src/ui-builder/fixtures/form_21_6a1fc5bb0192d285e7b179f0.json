{
  "version": "1",
  "actions": {
    "setShiftByTime": {
      "body": "function getShift(timeString) {\n    const hours = parseInt(timeString.split(':')[0], 10);\n    if (hours >= 6 && hours < 14) {\n        return 'A';\n    } else if (hours >= 14 && hours < 22) {\n        return 'B';\n    } else {\n        return 'C';\n    }\n}\n\nconst targetKey = `${args.field_data_key}`;\nconst time = e.args[0];\nconst shift = getShift(time);\ne.data[targetKey] = shift;",
      "params": {
        "field_data_key": "string"
      }
    },
    "setDefaultDateTime": {
      "body": "const now = new Date().toISOString(); e.store.form.data.rsDateTime = now;",
      "params": {}
    },
    "set_upload_url": {
      "body": "const attachmentKey = args.field_data_key;  // Changed from args.attachment_key\n\nif (e.args[1]?.fileKey && e.args[0]?.file_url) {\n    if (!window.__fileUrlMap) window.__fileUrlMap = {};\n    window.__fileUrlMap[e.args[1].fileKey] = e.args[0].file_url;\n\n    if (e.data[attachmentKey]) {\n        e.data[attachmentKey].forEach(item => {\n            if (window.__fileUrlMap[item.fileKey]) {\n                item.file_url = window.__fileUrlMap[item.fileKey];\n                item.status = 'finished';\n            }\n        });\n    }\n}",
      "params": {
        "field_data_key": "string"
      }
    },
    "on_time_mount": {
      "body": "const targetKeySelf = `${args.self_data_key_name}`;\n\nif(!e.data[targetKeySelf]){\n    e.data[targetKeySelf] = new Date();\n}\n\nfunction getShift(timeString) {\n    const hours = parseInt(timeString.split(':')[0], 10);\n    if (hours >= 6 && hours < 14) {\n        return 'A';\n    } else if (hours >= 14 && hours < 22) {\n        return 'B';\n    } else {\n        return 'C';\n    }\n}\n\nif(!e.data?.shift){\n    const time = e.data[targetKeySelf];\n    const targetKey = `${args.field_data_key}`;\n    const shift = getShift(time);\n    e.data[targetKey] = shift;\n}",
      "params": {
        "field_data_key": "string",
        "self_data_key_name": "string"
      }
    },
    "set_date_on_mount": {
      "body": "const targetKey = `${args.field_data_key}`;\n\nif (!e.data[targetKey]) {\n    e.data[targetKey] = new Date();\n}",
      "params": {
        "field_data_key": "string"
      }
    }
  },
  "formValidator": "    const errors = {};\n    console.log(\"is rejecting\",window.__FORM_IS_REJECTING__);\n    if (window.__FORM_IS_REJECTING__) {\n        if (!formData.rejection_reason || formData.rejection_reason.toString().trim() === '') {\n            errors['rejection_reason'] = 'Please select a rejection reason';\n        }\n\n        // if (!formData.remarks || formData.remarks.toString().trim() === '') {\n        //     errors['remarks'] = 'Remarks is required when rejecting';\n        // }\n    }\n\n    return Object.keys(errors).length > 0 ? errors : undefined;\n",
