{
  "version": "1",
  "formValidator": "  const errors = {};\n\n  // Route validation - at least one route must be selected\n  const routeFields = Object.keys(formData).filter(key => key.startsWith('route__'));\n  const hasAtLeastOneRoute = routeFields.some(field => formData[field] === true);\n\n  if (!hasAtLeastOneRoute) {\n    errors.route__moulding = \"At least one route must be selected\";\n  }\n\n  // Extract current record ID from URL if in edit mode\n  // URL pattern: /logsheet/master/casting_master/completed/<id>/edit\n  let currentRecordId = null;\n  try {\n    const match = window.location.pathname.match(/\\/([a-f0-9]{24})\\/edit/i);\n    if (match) {\n      currentRecordId = match[1];\n    }\n  } catch (e) {\n    // window unavailable or path doesn't match — treat as new record\n  }\n\n  // Casting name duplicate validation\n  const castingName = formData.casting_name;\n\n  if (castingName && typeof castingName === 'string' && castingName.trim() !== '') {\n    try {\n      const savedToken = localStorage.getItem('dlms_auth_token');\n\n      if (savedToken) {\n        const res = await fetch('https://dlms-api.iotnp.com/api/v1/templates/casting_master/dropdown/v2', {\n          method: 'POST',\n          headers: {\n            'accept': 'application/json',\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${savedToken}`\n          },\n          body: JSON.stringify({\n            \"fields\": [\"data.main.data.casting_name\", \"id\"],\n            \"search_fields\": [\"data.main.data.casting_name\"],\n            \"search\": castingName.trim(),\n            \"status\": \"completed\",\n            \"limit\": 100\n          })\n        });\n\n        if (res.ok) {\n          const response = await res.json();\n          const items = Array.isArray(response.data) ? response.data : [];\n\n          // Duplicate exists if name matches (case-insensitive) AND it's not the same record\n          const duplicateExists = items.some(item => {\n            const existingName = item[\"data.main.data.casting_name\"] || \"\";\n            const existingId = item.id || item._id;\n            const nameMatches = existingName.toLowerCase() === castingName.trim().toLowerCase();\n            const isSameRecord = currentRecordId && String(existingId) === String(currentRecordId);\n            return nameMatches && !isSameRecord;\n          });\n\n          if (duplicateExists) {\n            errors.casting_name = `Casting name \"${castingName}\" already exists. Please use a different name.`;\n          }\n        }\n      }\n    } catch (err) {\n      console.error(\"Duplicate check error:\", err);\n      // Don't block submission on API error, just log it\n    }\n  }\n\n  return Object.keys(errors).length > 0 ? errors : undefined;",
