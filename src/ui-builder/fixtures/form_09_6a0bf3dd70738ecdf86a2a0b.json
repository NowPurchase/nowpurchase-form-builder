  "actions": {
    "setShiftByTime": {
      "body": "function getShift(timeString) {\n    const hours = parseInt(timeString.split(':')[0], 10);\n    if (hours >= 6 && hours < 14) {\n        return 'A';\n    } else if (hours >= 14 && hours < 22) {\n        return 'B';\n    } else {\n        return 'C';\n    }\n}\n\nconst targetKey = `${args.field_data_key}`;\nconst time = e.args[0];\nconst shift = getShift(time);\ne.data[targetKey] = shift;",
      "params": {
        "field_data_key": "string"
      }
    },
    "set_current_logged_in_user": {
      "body": "if (e?.data?.disabled__supervisor ) {\n    return e?.data?.disabled__supervisor;\n}\nlet savedToken = localStorage.getItem('tokenv2') || localStorage.getItem('nowpurchase_token');\n\nconst finalToken = savedToken;\n\nfetch('https://api.nowpurchase.com/api/user-detail/', {\n    method: 'GET',\n    headers: {\n        'accept': 'application/json',\n        'authorization': `Token ${finalToken}`\n    }\n})\n.then(res => res.json())\n.then(userData => {\n    if (userData && userData.name) {\n        e.data.disabled__supervisor = userData.name;\n    }\n})\n.catch((error) => {\n    console.error('Fetch error:', error);\n});",
      "params": {}
    },
    "upload_url_set": {
      "body": "    if (e.args[1]?.fileKey && e.args[0]?.file_url) {\n        // Store in global map\n        if (!window.__fileUrlMap) window.__fileUrlMap = {};\n        window.__fileUrlMap[e.args[1].fileKey] = e.args[0].file_url;\n\n        // Sync ALL stored URLs to current attachment array\n        if (e.data.attachment) {\n            e.data.attachment.forEach(item => {\n                if (window.__fileUrlMap[item.fileKey]) {\n                    item.file_url = window.__fileUrlMap[item.fileKey];\n                    item.status = 'finished';\n                }\n            });\n        }\n    }",
      "params": {}
    },
    "set_time_on_mount": {
      "body": "if(!e.data?.time){\n    e.data.time = new Date();\n}\n\nfunction getShift(timeString) {\n    const hours = parseInt(timeString.split(':')[0], 10);\n    if (hours >= 6 && hours < 14) {\n        return 'A';\n    } else if (hours >= 14 && hours < 22) {\n        return 'B';\n    } else {\n        return 'C';\n    }\n}\n\nif(!e.data?.shift){\n    const time = e.data.time;\n    const shift = getShift(time);\n    e.data[\"shift\"] = shift;\n}",
      "params": {}
    },
    "set_date_on_mount": {
      "body": "if(!e.data?.date){\n    e.data.date = new Date();\n}",
      "params": {}
    }
  },
