                        "computeType": "function",
                        "fnSource": "    var pouringDate = form.data.parent_data__pouring_date; // e.g., \"2026-05-11\"\n    var pouringTime = form.data.parent_data__pouring_time; // e.g., \"00:04:00\"\n    var formatted = pouringDate;\n\n    try {\n        if (pouringDate && pouringTime) {\n            // Combine into a parseable datetime string\n            // Treat as local IST time (no Z, no offset)\n            var date = new Date(pouringDate + 'T' + pouringTime);\n\n            if (!isNaN(date.getTime())) {\n                var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n                              'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n\n                var month = months[date.getMonth()];\n                var day = date.getDate();\n                var year = date.getFullYear();\n\n                var hours = date.getHours();\n                var minutes = date.getMinutes();\n                var ampm = hours >= 12 ? 'PM' : 'AM';\n\n                hours = hours % 12;\n                hours = hours ? hours : 12;\n\n                var minutesStr = minutes < 10 ? '0' + minutes : minutes;\n\n                // Format: \"May 11, 2026 - 12:04 AM\"\n                formatted = month + ' ' + day + ', ' + year + ' - ' + hours + ':' + minutesStr + ' ' + ampm;\n            }\n        } else if (pouringDate) {\n            // Date only, no time available\n            var dateOnly = new Date(pouringDate + 'T00:00:00');\n            if (!isNaN(dateOnly.getTime())) {\n                var months2 = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',\n                               'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n                formatted = months2[dateOnly.getMonth()] + ' ' + dateOnly.getDate() + ', ' + dateOnly.getFullYear();\n            }\n        }\n    } catch (e) {\n        // Return original value on error\n    }\n\n    return \"Pouring Date: \" + formatted;"
                      },
